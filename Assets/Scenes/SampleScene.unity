--- !u!114 &587873404
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 587873401}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e2d76ba67659a654480b134fa12256d9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  _npcName: Farmer
  _rootNode:
    npcText: Morning. The crops need water and the animals need care. That is farm
      life.
    choices:
    - choiceText: Need help?
      nextNode:
        rid: 6491332098143551605
    - choiceText: Nice crops.
      nextNode:
        rid: 6491332098143551606
    - choiceText: What animals do you raise?
      nextNode:
        rid: 6491332098143551607
  _npcData:
    npcName: Farmer
    friendshipPoints: 0
    lowFriendshipDialogue:
      npcText: Morning. The crops need water and the animals need care. That is farm
        life.
      choices:
      - choiceText: Need help?
        nextNode:
          rid: 6491332098143551608
      - choiceText: Nice crops.
        nextNode:
          rid: 6491332098143551609
      - choiceText: What animals do you raise?
        nextNode:
          rid: 6491332098143551610
    midFriendshipDialogue:
      npcText: The farm is holding together well this season.
      choices:
      - choiceText: Any advice?
        nextNode:
          rid: 6491332098143551611
      - choiceText: How are the animals?
        nextNode:
          rid: 6491332098143551612
      - choiceText: What are you growing?
        nextNode:
          rid: 6491332098143551613
    highFriendshipDialogue:
      npcText: Partner, you have become part of this place.
      choices:
      - choiceText: Show me the barn.
        nextNode:
          rid: 6491332098143551614
      - choiceText: Can I help harvest?
        nextNode:
          rid: 6491332098143551615
      - choiceText: Thanks, Farmer.
        nextNode:
          rid: 6491332098143551616
  _dialoguePanel: {fileID: 1891105239}
  _npcNameText: {fileID: 832877394}
  _npcText: {fileID: 285840801}
  _choiceButtonPrefab: {fileID: 8246148749650536893, guid: 574e67bcc3a729f48909719976ff9022, type: 3}
  _choicesContainer: {fileID: 583042930}
  references:
    version: 2
    RefIds:
    - rid: 6491332098143551605
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Always. Start with feeding the animals in the barn.
        choices: []
    - rid: 6491332098143551606
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Thanks. Good soil and patience do most of the work.
        choices: []
    - rid: 6491332098143551607
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Chickens for eggs, cows for milk, and sheep for wool.
        choices: []
    - rid: 6491332098143551608
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Always. Start with feeding the animals in the barn.
        choices: []
    - rid: 6491332098143551609
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Thanks. Good soil and patience do most of the work.
        choices: []
    - rid: 6491332098143551610
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Chickens for eggs, cows for milk, and sheep for wool.
        choices: []
    - rid: 6491332098143551611
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Water early and check every animal daily.
        choices: []
    - rid: 6491332098143551612
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: They stay productive when they are fed and happy.
        choices: []
    - rid: 6491332098143551613
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Wheat, carrots, and anything the shop can keep in stock.
        choices: []
    - rid: 6491332098143551614
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Come by. The animals are settled in there.
        choices: []
    - rid: 6491332098143551615
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: When the crops are ready, every hand helps.
        choices: []
    - rid: 6491332098143551616
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: You earned it.
        choices: []
