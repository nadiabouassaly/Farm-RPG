  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  _npcName: Villager
  _rootNode:
    npcText: Oh, hello. Welcome to the village.
    choices:
    - choiceText: What is this place like?
      nextNode:
        rid: 6491332098143551617
    - choiceText: Where should I visit?
      nextNode:
        rid: 6491332098143551618
    - choiceText: Nice to meet you.
      nextNode:
        rid: 6491332098143551619
  _npcData:
    npcName: Villager
    friendshipPoints: 0
    lowFriendshipDialogue:
      npcText: Oh, hello. Welcome to the village.
      choices:
      - choiceText: What is this place like?
        nextNode:
          rid: 6491332098143551620
      - choiceText: Where should I visit?
        nextNode:
          rid: 6491332098143551621
      - choiceText: Nice to meet you.
        nextNode:
          rid: 6491332098143551622
    midFriendshipDialogue:
      npcText: Hey neighbor. Beautiful day, right?
      choices:
      - choiceText: What is happening?
        nextNode:
          rid: 6491332098143551623
      - choiceText: Do you like the farm?
        nextNode:
          rid: 6491332098143551624
      - choiceText: Want to walk?
        nextNode:
          rid: 6491332098143551625
    highFriendshipDialogue:
      npcText: There you are. I was hoping you would come by.
      choices:
      - choiceText: What is new?
        nextNode:
          rid: 6491332098143551626
      - choiceText: Good to see you.
        nextNode:
          rid: 6491332098143551627
      - choiceText: Let's visit the park.
        nextNode:
          rid: 6491332098143551628
  _dialoguePanel: {fileID: 1891105239}
  _npcNameText: {fileID: 832877394}
  _npcText: {fileID: 285840801}
  _choiceButtonPrefab: {fileID: 8246148749650536893, guid: 574e67bcc3a729f48909719976ff9022, type: 3}
  _choicesContainer: {fileID: 583042930}
  references:
    version: 2
    RefIds:
    - rid: 6491332098143551617
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Quiet, friendly, and usually smelling like fresh soil.
        choices: []
    - rid: 6491332098143551618
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The park is peaceful, and the shop is useful.
        choices: []
    - rid: 6491332098143551619
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Nice to meet you too.
        choices: []
    - rid: 6491332098143551620
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Quiet, friendly, and usually smelling like fresh soil.
        choices: []
    - rid: 6491332098143551621
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The park is peaceful, and the shop is useful.
        choices: []
    - rid: 6491332098143551622
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Nice to meet you too.
        choices: []
    - rid: 6491332098143551623
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Everyone is getting ready for the next harvest.
        choices: []
    - rid: 6491332098143551624
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The animals make the place feel alive.
        choices: []
    - rid: 6491332098143551625
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The park is my favorite route.
        choices: []
    - rid: 6491332098143551626
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The town is planning a small harvest table.
        choices: []
    - rid: 6491332098143551627
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Good to see you too.
        choices: []
    - rid: 6491332098143551628
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Yes, the flowers look best near sunset.
        choices: []
