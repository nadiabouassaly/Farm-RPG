  m_Script: {fileID: 11500000, guid: e2d76ba67659a654480b134fa12256d9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  _npcName: ShopKeeper
  _rootNode:
    npcText: Welcome to my shop. I sell seeds, tools, and animal feed. What can I
      help you with today?
    choices:
    - choiceText: What seeds do you have?
      nextNode:
        rid: 6491332098143551593
    - choiceText: I need animal feed.
      nextNode:
        rid: 6491332098143551594
    - choiceText: Just looking around.
      nextNode:
        rid: 6491332098143551595
  _npcData:
    npcName: ShopKeeper
    friendshipPoints: 0
    lowFriendshipDialogue:
      npcText: Welcome to my shop. I sell seeds, tools, and animal feed. What can
        I help you with today?
      choices:
      - choiceText: What seeds do you have?
        nextNode:
          rid: 6491332098143551596
      - choiceText: I need animal feed.
        nextNode:
          rid: 6491332098143551597
      - choiceText: Just looking around.
        nextNode:
          rid: 6491332098143551598
    midFriendshipDialogue:
      npcText: Good to see you again. Need anything for the farm today?
      choices:
      - choiceText: Any new stock?
        nextNode:
          rid: 6491332098143551599
      - choiceText: How is business?
        nextNode:
          rid: 6491332098143551600
      - choiceText: Any farming tip?
        nextNode:
          rid: 6491332098143551601
    highFriendshipDialogue:
      npcText: My favorite regular. I saved the best stock for you.
      choices:
      - choiceText: What did you save?
        nextNode:
          rid: 6491332098143551602
      - choiceText: Any discount?
        nextNode:
          rid: 6491332098143551603
      - choiceText: Thanks!
        nextNode:
          rid: 6491332098143551604
  _dialoguePanel: {fileID: 1891105239}
  _npcNameText: {fileID: 832877394}
  _npcText: {fileID: 285840801}
  _choiceButtonPrefab: {fileID: 8246148749650536893, guid: 574e67bcc3a729f48909719976ff9022, type: 3}
  _choicesContainer: {fileID: 583042930}
  references:
    version: 2
    RefIds:
    - rid: 6491332098143551593
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: I have wheat, carrot, potato, and seasonal seeds ready for the farm.
        choices: []
    - rid: 6491332098143551594
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The feed sacks by the counter work for chickens, cows, and sheep.
        choices: []
    - rid: 6491332098143551595
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Take your time. The shop is open during the day.
        choices: []
    - rid: 6491332098143551596
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: I have wheat, carrot, potato, and seasonal seeds ready for the farm.
        choices: []
    - rid: 6491332098143551597
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The feed sacks by the counter work for chickens, cows, and sheep.
        choices: []
    - rid: 6491332098143551598
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Take your time. The shop is open during the day.
        choices: []
    - rid: 6491332098143551599
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: I restock seeds every new day, especially in season.
        choices: []
    - rid: 6491332098143551600
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Better now that the town is busier.
        choices: []
    - rid: 6491332098143551601
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Keep your animals fed before expecting good products.
        choices: []
    - rid: 6491332098143551602
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Fresh premium feed. Your animals will love it.
        choices: []
    - rid: 6491332098143551603
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: For you, I can always make a fair deal.
        choices: []
    - rid: 6491332098143551604
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Any time. A good farm keeps the whole town alive.
        choices: []
